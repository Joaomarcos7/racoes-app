generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Produto {
  id             String             @id @default(cuid())
  nome           String
  peso           Float
  valorUnitario  Float
  custo          Float?
  tipo           TipoProduto        @default(CONSUMIDOR_FINAL)
  ativo          Boolean            @default(true)
  createdAt      DateTime           @default(now())
  itens          ItemPedido[]
  historico      HistoricoProduto[]
  historicoCusto HistoricoCusto[]
}

model HistoricoProduto {
  id            String   @id @default(cuid())
  produtoId     String
  produto       Produto  @relation(fields: [produtoId], references: [id])
  precoAnterior Float
  precoNovo     Float
  criadoEm      DateTime @default(now())
}

model HistoricoCusto {
  id            String   @id @default(cuid())
  produtoId     String
  produto       Produto  @relation(fields: [produtoId], references: [id])
  custoAnterior Float?
  custoNovo     Float?
  criadoEm      DateTime @default(now())
}

model Cliente {
  id          String   @id @default(cuid())
  nome        String
  telefone    String?
  instituicao String?
  cidade      String
  cep         String?
  endereco    String?
  complemento String?
  ativo       Boolean  @default(true)
  createdAt   DateTime @default(now())
  pedidos     Pedido[]
}

model Veiculo {
  id         String             @id @default(cuid())
  placa      String             @unique
  modelo     String
  pesoMaximo Float
  ativo      Boolean            @default(true)
  rotas      ConsolidacaoRota[]
}

model Pedido {
  id                   String             @id @default(cuid())
  tipoPedido           TipoPedido         @default(ENTREGA)
  clienteId            String?
  cliente              Cliente?           @relation(fields: [clienteId], references: [id])
  dataPedido           DateTime           @default(now())
  statusEntrega        StatusEntrega?
  statusPagamento      StatusPagamento    @default(PENDENTE)
  metodoPagamento      MetodoPagamento?
  observacoes          String?
  dataVencimentoFiado  DateTime?
  desconto             Float              @default(0)
  ativo                Boolean            @default(true)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  itens                ItemPedido[]
  consolidacoes        ConsolidacaoItem[]
  historicoStatus      HistoricoStatusPedido[]
}

model HistoricoStatusPedido {
  id              String        @id @default(cuid())
  pedidoId        String
  pedido          Pedido        @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  statusAnterior  StatusEntrega?
  statusNovo      StatusEntrega
  criadoEm        DateTime      @default(now())
}

model ItemPedido {
  id         String  @id @default(cuid())
  pedidoId   String
  pedido     Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId  String
  produto    Produto @relation(fields: [produtoId], references: [id])
  quantidade Int
  pesoUnit   Float
  valorUnit  Float
}

model ConsolidacaoRota {
  id        String             @id @default(cuid())
  data      DateTime           @default(now())
  veiculoId String
  veiculo   Veiculo            @relation(fields: [veiculoId], references: [id])
  status    StatusRota         @default(ABERTA)
  createdAt DateTime           @default(now())
  itens     ConsolidacaoItem[]
}

model ConsolidacaoItem {
  id                 String           @id @default(cuid())
  consolidacaoRotaId String
  rota               ConsolidacaoRota @relation(fields: [consolidacaoRotaId], references: [id], onDelete: Cascade)
  pedidoId           String           @unique
  pedido             Pedido           @relation(fields: [pedidoId], references: [id])
}

enum StatusEntrega {
  AGUARDANDO
  EM_ROTA
  ENTREGUE
}

enum StatusPagamento {
  PENDENTE
  PAGO
  FIADO
}

enum MetodoPagamento {
  DINHEIRO
  PIX
  BOLETO
  CHEQUE
  CARTAO_CREDITO
  CARTAO_DEBITO
}

enum StatusRota {
  ABERTA
  FECHADA
}

model Notificacao {
  id        String          @id @default(cuid())
  tipo      TipoNotificacao
  texto     String
  lida      Boolean         @default(false)
  criadoEm  DateTime        @default(now())
  pedidoId  String?
}

enum TipoNotificacao {
  FIADO_VENCIDO
  PEDIDO_ENTREGUE
}

enum TipoPedido {
  ENTREGA
  BALCAO
}

enum TipoProduto {
  CONSUMIDOR_FINAL
  ATACADO
}
